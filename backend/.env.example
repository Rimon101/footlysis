# SQLite (default, zero setup)
DATABASE_URL=sqlite+aiosqlite:///./footlysis.db

# PostgreSQL (uncomment to use instead)
# DATABASE_URL=postgresql+asyncpg://postgres:password@localhost:5432/footlysis
SECRET_KEY=footlysis-secret-key-change-in-production
ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=10080
FOOTBALL_DATA_API_KEY=Api_Footbal
ENVIRONMENT=development
